# Google Cloud Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GKE_CLUSTER_NAME=poker-cluster
GKE_ZONE=us-central1-a

# Docker Configuration
DOCKER_REGISTRY=gcr.io
BACKEND_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest

# Backend Configuration
BACKEND_PORT=8080
BACKEND_REPLICAS=2

# Frontend Configuration
FRONTEND_PORT=80
FRONTEND_REPLICAS=2

# Application Configuration
CORS_ALLOWED_ORIGINS=*
LOG_LEVEL=info

# Machine Type Options: n1-standard-1, n1-standard-2, n1-standard-4, n1-highmem-2, etc.
MACHINE_TYPE=n1-standard-2
NUMBER_OF_NODES=2

# Kubernetes Resources
BACKEND_CPU_REQUEST=100m
BACKEND_CPU_LIMIT=500m
BACKEND_MEMORY_REQUEST=128Mi
BACKEND_MEMORY_LIMIT=256Mi

FRONTEND_CPU_REQUEST=100m
FRONTEND_CPU_LIMIT=500m
FRONTEND_MEMORY_REQUEST=128Mi
FRONTEND_MEMORY_LIMIT=256Mi
